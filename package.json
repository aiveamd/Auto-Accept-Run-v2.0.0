{
	"name": "antigravity-auto-accept-custom",
	"displayName": "Auto Accept Agent (Unlocked)",
	"description": "Auto-accept file edits, terminal commands, and agent prompts. Based on MunKhin's Auto Accept Agent, all features unlocked.",
	"version": "12.7.1",
	"publisher": "custom",
	"license": "MIT",
	"icon": "icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/aiveamd/Auto-Accept-Run-v2.0.0"
	},
	"categories": [
		"Machine Learning",
		"Other"
	],
	"keywords": [
		"antigravity",
		"cursor",
		"ai",
		"auto-accept"
	],
	"engines": {
		"vscode": "^1.75.0"
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "auto-accept.toggle",
				"title": "Auto Accept: Toggle ON/OFF"
			},
			{
				"command": "auto-accept.toggleBackground",
				"title": "Auto Accept: Toggle Background Mode"
			},
			{
				"command": "auto-accept.openSettings",
				"title": "Auto Accept: Settings"
			},
			{
				"command": "auto-accept.generateSessionSummary",
				"title": "Auto Accept: Generate Session Summary"
			}
		]
	},
	"dependencies": {
		"ws": "^8.13.0"
	},
	"devDependencies": {
		"esbuild": "^0.27.3"
	}
}